# Server
PORT=3000
SMTP_PORT=25

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Mail settings
MAIL_TTL=3600          # seconds - email tự xóa sau 1 giờ
MAX_EMAILS_PER_BOX=50  # tối đa 50 mail mỗi inbox
MAX_EMAIL_SIZE=5242880 # 5MB

# Domains (phân cách bằng dấu phẩy)
ALLOWED_DOMAINS=domain1.com,domain2.com,domain3.com

# Telegram Bot (tùy chọn - bỏ trống nếu không dùng)
TELEGRAM_BOT_TOKEN=

# Admin Panel — bắt buộc nếu dùng /admin (tối thiểu 16 ký tự)
ADMIN_SECRET=change-me-use-a-long-random-string

# Cloudflare Email Worker inbound (để trống nếu không dùng)
# Phải khớp với INBOUND_SECRET trong Cloudflare Worker settings
INBOUND_SECRET=
